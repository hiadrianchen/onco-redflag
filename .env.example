# 复制为 .env（已被 .gitignore 忽略），填入你领取的 Key。切勿提交真实 Key 到仓库。
# 用法：set -a; source .env; set +a   然后运行 pipeline。

# KnowS 医学循证检索（团队 API Key，活动期有效，共享额度池）
KNOWS_API_KEY=sk-knows-xxxxxxxxxxxxxxxx
# evidence-lookup 默认走 local provider；设为 1 才走 KnowS 在线检索（失败自动回退 local）
KNOWS_USE=0

# StepFun 大模型（用于后续自由文本 intake；当前表单版 intake 不需要）
STEPFUN_API_KEY=sk-xxxxxxxxxxxxxxxx
